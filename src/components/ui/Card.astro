---
const {
  class: className = "",
  padding = "p-8",
  hover = true
} = Astro.props;
---

<div
class={`
relative
overflow-hidden
rounded-2xl
border
border-white/10
bg-white/[0.03]
backdrop-blur-sm
${padding}
${hover ? "transition duration-300 hover:-translate-y-1 hover:border-white/20" : ""}
${className}
`}
>

<slot />

</div>