---
import Container from "./ui/Container.astro";
import SectionHeader from "./ui/SectionHeader.astro";
import Card from "./ui/Card.astro";
import Button from "./ui/Button.astro";
import Metadata from "./ui/Metadata.astro";
---

<section
id="portfolio"
class="
section
section-dark
"
>

<Container>


<SectionHeader

eyebrow="VISUAL ARCHIVE // 02"

title="Alaska"

subtitle="Unseen"

description="A curated archive of aerial expeditions documenting Alaska's coastlines, mountains, glaciers, and remote wilderness."

/>



<div
class="
grid
md:grid-cols-2
gap-8
"
>





<!-- Outer Point -->

<Card
padding="p-0"
>

<div
class="
aspect-video
overflow-hidden
"
>

<iframe
class="
w-full
h-full
"
src="https://www.youtube.com/embed/syklTmTOyRg"
title="Outer Point Expedition"
frameborder="0"
allowfullscreen
>
</iframe>

</div>


<div
class="
p-6
space-y-6
"
>

<h3
class="
font-heading
text-3xl
uppercase
"
>
Outer Point Expedition
</h3>


<p
class="
text-gray-400
leading-relaxed
"
>
Coastal aerial documentation exploring the rugged shoreline,
forests, and island landscapes of Southeast Alaska.
</p>


<div
class="
grid
grid-cols-2
gap-6
"
>

<Metadata
label="Region"
value="Juneau, Alaska"
/>


<Metadata
label="Format"
value="4K Aerial"
/>

</div>


</div>


</Card>







<!-- Point Bridget -->

<Card
padding="p-0"
>

<div
class="
aspect-video
overflow-hidden
"
>

<iframe
class="
w-full
h-full
"
src="https://www.youtube.com/embed/eED70PqU-hI"
title="Point Bridget Expedition"
frameborder="0"
allowfullscreen
>
</iframe>

</div>


<div
class="
p-6
space-y-6
"
>

<h3
class="
font-heading
text-3xl
uppercase
"
>
Point Bridget Expedition
</h3>


<p
class="
text-gray-400
leading-relaxed
"
>
Aerial exploration of Alaska's coastal wilderness,
capturing the connection between forest, mountains,
and ocean.
</p>


<div
class="
grid
grid-cols-2
gap-6
"
>

<Metadata
label="Environment"
value="Coastal Wilderness"
/>


<Metadata
label="Capture"
value="Drone Media"
/>

</div>


</div>


</Card>


</div>







<div
class="
mt-12
"
>

<Button

href="https://www.youtube.com/channel/UC_3iTbiuo9_5zGLFFsWH-Vg"

text="Access Full Archive →"

/>

</div>



</Container>

</section>