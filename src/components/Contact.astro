---
import Container from "./ui/Container.astro";
import SectionHeader from "./ui/SectionHeader.astro";
import Card from "./ui/Card.astro";
import Metadata from "./ui/Metadata.astro";
---

<section
id="contact"
class="
section
section-slate
"
>

<Container>


<SectionHeader

eyebrow="TRANSMISSION // 05"

title="Start"

subtitle="A Project"

description="Have a location, story, or commercial project in mind? Begin planning your next aerial production."

/>




<div
class="
grid
lg:grid-cols-2
gap-10
"
>





<Card>


<div
class="
space-y-8
"
>


<div>

<h3
class="
font-heading
text-3xl
uppercase
"
>
RavenØrix Operations
</h3>


<p
class="
mt-3
text-gray-400
leading-relaxed
"
>
Cinematic aerial media production supporting
commercial projects, creators, and organizations
throughout Southeast Alaska.
</p>

</div>




<div
class="
space-y-5
"
>

<Metadata
label="Region"
value="Southeast Alaska"
/>


<Metadata
label="Certification"
value="FAA Part 107 Commercial Remote Pilot"
/>


<Metadata
label="Services"
value="Aerial Media Production"
/>


</div>



</div>


</Card>







<Card>


<form
name="contact"
method="POST"
data-netlify="true"
class="
space-y-5
"
>


<input
type="hidden"
name="form-name"
value="contact"
/>



<input
type="text"
name="name"
placeholder="Name"
class="
w-full
rounded-lg
bg-black/40
border
border-white/10
px-4
py-3
text-white
placeholder-white/40
"
/>




<input
type="email"
name="email"
placeholder="Email"
class="
w-full
rounded-lg
bg-black/40
border
border-white/10
px-4
py-3
text-white
placeholder-white/40
"
/>




<input
type="text"
name="organization"
placeholder="Organization / Company"
class="
w-full
rounded-lg
bg-black/40
border
border-white/10
px-4
py-3
text-white
placeholder-white/40
"
/>





<input
type="text"
name="project"
placeholder="Project Type"
class="
w-full
rounded-lg
bg-black/40
border
border-white/10
px-4
py-3
text-white
placeholder-white/40
"
/>





<textarea
name="message"
rows="5"
placeholder="Tell us about your location, timeline, and project goals..."
class="
w-full
rounded-lg
bg-black/40
border
border-white/10
px-4
py-3
text-white
placeholder-white/40
"
></textarea>





<button
type="submit"
class="
bg-glacier-blue
text-raven-black
px-8
py-4
rounded-lg
font-semibold
transition
hover:scale-[1.03]
"
>
Send Transmission →
</button>



</form>


</Card>



</div>




</Container>

</section>