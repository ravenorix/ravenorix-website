---
import Container from "./ui/Container.astro";
import SectionHeader from "./ui/SectionHeader.astro";
import Card from "./ui/Card.astro";
import Metadata from "./ui/Metadata.astro";
import Button from "./ui/Button.astro";
---

<section
id="services"
class="
section
section-slate
"
>

<Container>


<SectionHeader

eyebrow="OPERATIONS // 03"

title="Commercial"

subtitle="Services"

description="Professional aerial media solutions for organizations, creators, and businesses requiring cinematic perspectives from Alaska's unique environments."

/>



<div
class="
grid
md:grid-cols-3
gap-8
"
>



<Card>


<h3
class="
font-heading
text-3xl
uppercase
"
>
Aerial Production
</h3>


<p
class="
mt-4
text-gray-400
leading-relaxed
"
>
Cinematic aerial footage and photography created for
documentaries, marketing campaigns, tourism projects,
and visual storytelling.
</p>


<div
class="
mt-8
"
>

<Metadata
label="Output"
value="4K Cinematic Media"
/>

</div>


</Card>





<Card>


<h3
class="
font-heading
text-3xl
uppercase
"
>
Location Media
</h3>


<p
class="
mt-4
text-gray-400
leading-relaxed
"
>
Showcase destinations, properties, and experiences with
authentic aerial perspectives built around Alaska's
remote environments.
</p>


<div
class="
mt-8
"
>

<Metadata
label="Focus"
value="Tourism & Brand Media"
/>

</div>


</Card>





<Card>


<h3
class="
font-heading
text-3xl
uppercase
"
>
Custom Projects
</h3>


<p
class="
mt-4
text-gray-400
leading-relaxed
"
>
Collaborative aerial solutions designed around unique
locations, creative concepts, and specialized production
requirements.
</p>


<div
class="
mt-8
"
>

<Metadata
label="Certification"
value="FAA Part 107"
/>

</div>


</Card>



</div>




<div
class="
mt-12
"
>

<Button

href="#contact"

text="Start A Project →"

/>

</div>




</Container>

</section>