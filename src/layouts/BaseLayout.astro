---
import "../styles/global.css";

import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";


const {
title="RavenØrix | Cinematic Alaska Drone Media",
description="Professional Alaska drone footage, aerial photography, and FAA Part 107 commercial drone services."
}=Astro.props;

---

<html lang="en">

<head>

<meta charset="UTF-8" />

<meta
name="viewport"
content="width=device-width, initial-scale=1.0"
/>


<title>
{title}
</title>


<meta
name="description"
content={description}
/>


<meta
name="keywords"
content="
Alaska drone footage,
Alaska aerial photography,
Juneau drone services,
commercial drone pilot,
FAA Part 107,
Alaska videography,
cinematic drone footage
"
/>


<meta
name="author"
content="RavenØrix"
/>


<!-- Open Graph -->

<meta
property="og:title"
content={title}
/>


<meta
property="og:description"
content={description}
/>


<meta
property="og:type"
content="website"
/>


<meta
property="og:image"
content="/images/social-preview.png"
/>



<!-- Twitter -->

<meta
name="twitter:card"
content="summary_large_image"
/>


<meta
name="twitter:title"
content={title}
/>


<meta
name="twitter:description"
content={description}
/>


<meta
name="twitter:image"
content="/images/social-preview.png"
/>


<link
rel="icon"
href="/favicon.svg"
/>


</head>


<body>

<Navbar />

<main>

<slot />

</main>


<Footer />


</body>

</html>