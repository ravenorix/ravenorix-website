---
import "../styles/global.css";

import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";

const {
  title = "RavenØrix | Cinematic Alaska Drone Media",
  description =
    "Professional Alaska drone footage, aerial photography, and FAA Part 107 commercial drone services.",
} = Astro.props;
---

<html lang="en">
<head>
  <meta charset="UTF-8" />

  <meta
    name="viewport"
    content="width=device-width, initial-scale=1.0"
  />

  <title>{title}</title>

  <meta
    name="description"
    content={description}
  />

  <meta
    name="keywords"
    content="
    Alaska drone footage,
    Alaska aerial photography,
    Juneau drone services,
    Southeast Alaska videography,
    commercial drone pilot,
    FAA Part 107,
    cinematic aerial media,
    Alaska wilderness photography
    "
  />

  <meta
    name="author"
    content="RavenØrix"
  />

  <meta
    name="theme-color"
    content="#05070a"
  />

  <link
    rel="canonical"
    href="https://ravenorix.com"
  />


  <!-- Open Graph -->

  <meta
    property="og:title"
    content={title}
  />

  <meta
    property="og:description"
    content={description}
  />

  <meta
    property="og:type"
    content="website"
  />

  <meta
    property="og:url"
    content="https://ravenorix.com"
  />

  <meta
    property="og:image"
    content="https://ravenorix.com/images/social-preview.png"
  />

  <meta
    property="og:site_name"
    content="RavenØrix"
  />


  <!-- Twitter / X -->

  <meta
    name="twitter:card"
    content="summary_large_image"
  />

  <meta
    name="twitter:title"
    content={title}
  />

  <meta
    name="twitter:description"
    content={description}
  />

  <meta
    name="twitter:image"
    content="https://ravenorix.com/images/social-preview.png"
  />


  <!-- Favicon -->

  <link
    rel="icon"
    href="/favicon.svg"
  />

</head>

  <body
    class="
      bg-raven-black
      text-white
      antialiased
      selection:bg-glacier-blue
      selection:text-black
    "
  >
    <!-- Global Background Effects -->

    <div class="fixed inset-0 -z-10 overflow-hidden">

      <div class="tech-grid"></div>

      <div
        class="section-glow"
        style="
          top:-250px;
          left:-250px;
        "
      ></div>

      <div
        class="section-glow"
        style="
          bottom:-250px;
          right:-250px;
        "
      ></div>

    </div>

    <Navbar />

    <main>

      <slot />

    </main>

    <Footer />

  </body>
</html>